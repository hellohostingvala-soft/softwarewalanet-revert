# =============================================================================
# .env.security.example
# Zero Trust Security Configuration — copy to .env.security and fill in values
# NEVER commit the real .env.security file to source control
# =============================================================================

# ---------------------------------------------------------------------------
# AES-256 Encryption Keys (generate with: openssl rand -hex 32)
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=your-256-bit-hex-key-here
ENCRYPTION_KEY_BACKUP=your-backup-256-bit-hex-key-here

# ---------------------------------------------------------------------------
# JWT Service Signing (generate with: openssl rand -base64 64)
# ---------------------------------------------------------------------------
JWT_SERVICE_SECRET=your-jwt-service-secret-here
JWT_SERVICE_AUDIENCE=softwarevala-api
JWT_SERVICE_ISSUER=softwarevala-backend
JWT_SERVICE_EXPIRY_SECONDS=300

# ---------------------------------------------------------------------------
# Payment Gateway Webhook Secrets (obtain from provider dashboards)
# ---------------------------------------------------------------------------
WEBHOOK_PAYPAL_SECRET=your-paypal-webhook-secret
WEBHOOK_PAYU_SECRET=your-payu-webhook-secret
WEBHOOK_STRIPE_SECRET=your-stripe-webhook-secret

# ---------------------------------------------------------------------------
# PayPal Credentials
# ---------------------------------------------------------------------------
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET_KEY=your-paypal-secret-key
PAYPAL_ENVIRONMENT=sandbox   # sandbox | production

# ---------------------------------------------------------------------------
# PayU Credentials
# ---------------------------------------------------------------------------
PAYU_MERCHANT_KEY=your-payu-merchant-key
PAYU_SALT_KEY=your-payu-salt-key
PAYU_ENVIRONMENT=test   # test | production

# ---------------------------------------------------------------------------
# Supabase (Service Role — NEVER expose in frontend)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Redis / Upstash (for distributed replay cache & rate limiting)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---------------------------------------------------------------------------
# Secrets Vault (optional — Vault / AWS Secrets Manager)
# ---------------------------------------------------------------------------
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=your-vault-token

# ---------------------------------------------------------------------------
# Fraud & Risk Engine
# ---------------------------------------------------------------------------
FRAUD_RISK_THRESHOLD=70           # 0-100: flag orders above this score
MAX_ORDERS_PER_IP_PER_HOUR=5
MAX_ORDERS_PER_USER_PER_DAY=10
FRAUD_ALERT_EMAIL=boss@softwarevala.com

# ---------------------------------------------------------------------------
# Financial Reconciliation Cron
# ---------------------------------------------------------------------------
RECONCILIATION_ALERT_EMAIL=boss@softwarevala.com
RECONCILIATION_CRON_SCHEDULE=0 2 * * *   # daily 02:00 UTC

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_ORDERS_PER_IP_PER_HOUR=5
RATE_LIMIT_PAYMENTS_PER_USER_PER_MINUTE=3

# ---------------------------------------------------------------------------
# TLS / Network
# ---------------------------------------------------------------------------
TLS_MIN_VERSION=TLSv1.3
HSTS_MAX_AGE=31536000
