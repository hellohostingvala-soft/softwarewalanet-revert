# Test Environment Configuration
NODE_ENV=test

# Test database (isolated from production)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=test-anon-key
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key

# Payment gateway test keys
STRIPE_TEST_SECRET_KEY=sk_test_placeholder
FLUTTERWAVE_TEST_SECRET_KEY=FLWSECK_TEST-placeholder
PAYU_TEST_KEY=test-payu-key
PAYU_TEST_SALT=test-payu-salt

# Webhook secrets
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder
FLUTTERWAVE_WEBHOOK_SECRET=flw_webhook_test_placeholder

# Encryption
ENCRYPTION_KEY=test-encryption-key-32-chars-0000
JWT_SECRET=test-jwt-secret-key-for-tests

# Redis (mock)
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_ORDERS_PER_HOUR=5
RATE_LIMIT_ORDERS_PER_DAY=10

# Fraud scoring thresholds
FRAUD_BLOCK_THRESHOLD=80
FRAUD_REVIEW_THRESHOLD=50
