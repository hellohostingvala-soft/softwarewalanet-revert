# =============================================================
# FIXED-PRICE MARKETPLACE — PAYMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# --- Fixed Price (do not change) ---
VITE_FIXED_PRICE=249
VITE_CURRENCY=USD
VITE_PAYMENT_GATEWAYS=flutterwave,stripe,payu

# --- Supabase ---
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-public-key>

# --- Flutterwave ---
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_WEBHOOK_SECRET=<your-flutterwave-webhook-secret>

# --- Stripe ---
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- PayU ---
PAYU_MERCHANT_KEY=<your-payu-merchant-key>
PAYU_SALT_KEY=<your-payu-salt-key>
PAYU_WEBHOOK_SECRET=<your-payu-webhook-secret>
PAYU_ENVIRONMENT=production   # or: test

# --- App ---
APP_BASE_URL=https://your-app-domain.com
