# ============================================================
# Software Vala – Production Environment Template
# ============================================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to source control.
# ============================================================

# ---------- Supabase ----------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>

# ---------- Application ----------
VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0
VITE_APP_NAME=SoftwareVala

# ---------- Error Tracking (optional) ----------
VITE_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# ---------- Payment Gateways (optional) ----------
VITE_STRIPE_PUBLIC_KEY=pk_live_...
VITE_RAZORPAY_KEY_ID=rzp_live_...

# ---------- Feature Flags ----------
VITE_ENABLE_2FA=true
VITE_ENABLE_AUDIT_LOGS=true
VITE_ENABLE_RATE_LIMITING=true
VITE_SESSION_TIMEOUT_MINUTES=30
VITE_MAX_CONCURRENT_SESSIONS=3

# ---------- Security (server-side – do NOT expose via VITE_ prefix) ----------
# The variables below are for server/edge functions only and must NOT have
# the VITE_ prefix.  They are listed here for documentation purposes.
#
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # Never expose to the browser
# JWT_SECRET=<32+ char random string>
# ENCRYPTION_KEY=<32+ char random string>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@softwarevala.net
# SMTP_PASS=<password>
# TOTP_ISSUER=SoftwareVala
