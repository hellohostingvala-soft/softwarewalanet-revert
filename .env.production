# Production Environment Configuration
# univercel-tech-forge - DigitalOcean + Cloudflare Infrastructure

# API Configuration - DigitalOcean Server
VITE_API_BASE_URL=https://softwarewala.net/api
VITE_API_URL=https://softwarewala.net/api
VITE_WS_URL=wss://softwarewala.net

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Cloudflare Configuration
VITE_CLOUDFLARE_ACCOUNT_ID=your_account_id
VITE_CLOUDFLARE_API_TOKEN=your_api_token
VITE_CLOUDFLARE_ZONE_ID=your_zone_id

# DigitalOcean Server Configuration
VITE_SERVER_HOST=138.68.64.80
VITE_SERVER_USER=root
VITE_APP_URL=https://softwarewala.net

# Application Configuration
VITE_APP_NAME=univercel-tech-forge
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Universal Technology Forge Platform

# Analytics and Monitoring
VITE_ENABLE_ANALYTICS=true
VITE_SENTRY_DSN=your-sentry-dsn

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_REAL_TIME=true
VITE_ENABLE_NOTIFICATIONS=true

# Security
VITE_ENABLE_CSP=true
VITE_API_RATE_LIMIT=100

# Development/Debug
VITE_DEBUG=false
VITE_LOG_LEVEL=error
NODE_ENV=production
