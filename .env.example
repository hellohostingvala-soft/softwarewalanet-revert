# Software Vala - Environment Variables Example
# Copy this file to .env and fill in your values

# ============ Supabase (Frontend) ============
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ============ Supabase (Backend / Edge Functions) ============
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============ OpenAI ============
# Used for AI features: VALA AI chat, CEO insights, AIRA assistant, content generation
OPENAI_API_KEY=sk-...

# ============ ElevenLabs ============
# Used for voice generation (AIRA notifications, demo narration)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ============ GitHub App ============
# Used for marketplace sync service
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...
GITHUB_APP_INSTALLATION_ID=your-installation-id
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_ORG=your-github-org-or-username
GITHUB_TOKEN=ghp_...

# ============ Vercel (CI/CD) ============
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
